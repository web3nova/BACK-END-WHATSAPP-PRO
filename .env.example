# ── Super Admin (seeded on first startup) ─────────────
SUPERADMIN_EMAIL=admin@yourapp.com
SUPERADMIN_PASSWORD=

# ── App ───────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
APP_URL=http://localhost:4000

# ── Auth ──────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=10m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# ── Frontend ──────────────────────────────────────────
FRONTEND_URL=https://your-frontend-domain.com

# ── PostgreSQL (Prisma) ───────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Redis / Upstash (rate-limit + BullMQ queues) ──────
# Get from: console.upstash.com → your database → Connect → Redis URL (rediss://)
REDIS_URL=rediss://default:<password>@<endpoint>.upstash.io:6379

# ── Vector DB (Qdrant Cloud) ──────────────────────────
# Get from: cloud.qdrant.io → your cluster → Connect
QDRANT_URL=https://<cluster-id>.sa-east-1-0.aws.cloud.qdrant.io
QDRANT_API_KEY=
QDRANT_COLLECTION=knowledge

# ── AI providers ──────────────────────────────────────
AI_CHAT_PROVIDER=anthropic
AI_EMBEDDING_PROVIDER=openai

# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_CHAT_MODEL=claude-opus-4-8

# OpenAI (embeddings + optional chat fallback)
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Google Gemini (optional third provider)
GOOGLE_GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.5-pro

# ── Object Storage (Cloudflare R2 / S3-compatible) ────
# Endpoint format: https://<account-id>.r2.cloudflarestorage.com  (NO bucket in URL)
STORAGE_ENDPOINT=
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_REGION=auto

# ── WhatsApp Cloud API ────────────────────────────────
# Get from: developers.facebook.com → your app
META_APP_ID=
META_APP_SECRET=
META_CONFIG_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v20.0

# ── Lenco (account verification / transfers) ────────
# Get from: dashboard.lenco.co → Settings → API Keys
LENCO_API_KEY=
LENCO_BASE_URL=https://api.lenco.co/access/v1

# ── Monnify (subscription billing) ───────────────────
# Get from: app.monnify.com → Settings → API Keys
MONNIFY_API_KEY=
MONNIFY_SECRET_KEY=
MONNIFY_CONTRACT_CODE=
MONNIFY_BASE_URL=https://api.monnify.com

# ── Payment Gateway (Paystack) ────────────────────────
PAYMENT_PROVIDER=paystack
PAYMENT_SECRET_KEY=
PAYMENT_PUBLIC_KEY=
PAYMENT_WEBHOOK_SECRET=

# ── Email (Nodemailer / Gmail SMTP) ───────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=no-reply@whatsapppro.com

# ── Customer auth (storefront shoppers) ─────────────────────────────
# Google OAuth client used for storefront customer login (same client as
# the frontend's VITE_GOOGLE_CLIENT_ID).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# WebAuthn relying-party ID: the registrable domain customers sign in on.
RP_ID=biziq.online
# Origins allowed for passkey ceremonies and the Google popup postMessage.
ALLOWED_ORIGINS=https://biziq.online,https://front-end-whatsapp-pro.vercel.app
