# ── App ───────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
APP_URL=http://localhost:4000

# ── Auth ──────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# ── Frontend ──────────────────────────────────────────
FRONTEND_URL=https://your-frontend-domain.com

# ── PostgreSQL (Prisma) ───────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Redis / Upstash (rate-limit + BullMQ queues) ──────
# Get from: console.upstash.com → your database → Connect → Redis URL (rediss://)
REDIS_URL=rediss://default:<password>@<endpoint>.upstash.io:6379

# ── Vector DB (Qdrant Cloud) ──────────────────────────
# Get from: cloud.qdrant.io → your cluster → Connect
QDRANT_URL=https://<cluster-id>.us-east4-0.gcp.cloud.qdrant.io
QDRANT_API_KEY=
QDRANT_COLLECTION=knowledge

# ── AI providers ──────────────────────────────────────
# Chat/tool-calling provider: anthropic | openai | gemini
AI_CHAT_PROVIDER=anthropic
# Embeddings provider (RAG pipeline)
AI_EMBEDDING_PROVIDER=openai

# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_CHAT_MODEL=claude-opus-4-8

# OpenAI (embeddings + optional chat fallback)
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Google Gemini (optional third provider)
GOOGLE_GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.5-pro

# ── Object Storage (S3-compatible) ────────────────────
# Works with Cloudflare R2, AWS S3, Backblaze B2, DigitalOcean Spaces, MinIO, etc.
# Cloudflare R2 endpoint example: https://<account-id>.r2.cloudflarestorage.com
STORAGE_ENDPOINT=
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_REGION=auto

# ── WhatsApp Cloud API ────────────────────────────────
# Get from: developers.facebook.com → your app
META_APP_ID=
META_APP_SECRET=
META_CONFIG_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v20.0

# ── Payment Gateway (Paystack) ────────────────────────
# Get from: dashboard.paystack.com → Settings → API Keys
PAYMENT_PROVIDER=paystack
PAYMENT_SECRET_KEY=
PAYMENT_PUBLIC_KEY=
PAYMENT_WEBHOOK_SECRET=

# ── Email (Nodemailer / Gmail SMTP) ───────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=no-reply@whatsapppro.com
