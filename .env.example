# ── App ───────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
APP_URL=http://localhost:4000

# ── Auth ──────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-too
JWT_REFRESH_EXPIRES_IN=7d

# ── PostgreSQL (Prisma) ───────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agentic_sales

# ── Redis (sessions, rate-limit, BullMQ) ──────────────
REDIS_URL=redis://localhost:6379

# ── Vector DB (Qdrant) ────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=knowledge

# ── AI: provider selection ────────────────────────────
# chat/tool-calling provider: anthropic | openai | gemini
AI_CHAT_PROVIDER=anthropic
# embeddings provider: openai
AI_EMBEDDING_PROVIDER=openai

# Anthropic (Claude — LLM + Tool Calling)
ANTHROPIC_API_KEY=
ANTHROPIC_CHAT_MODEL=claude-opus-4-8

# OpenAI (chat fallback + embeddings)
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Google Gemini
GOOGLE_GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.5-pro


# ── Storage (S3-compatible) ───────────────────────────
STORAGE_ENDPOINT=
STORAGE_BUCKET=agentic-sales
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_REGION=us-east-1

# ── WhatsApp Cloud API + Meta Embedded Signup ─────────
META_APP_ID=
META_APP_SECRET=
META_CONFIG_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v20.0

# ── Settlement (Fiat Payment Gateway) ─────────────────
# e.g. paystack | flutterwave | stripe
PAYMENT_PROVIDER=paystack
PAYMENT_SECRET_KEY=
PAYMENT_PUBLIC_KEY=
PAYMENT_WEBHOOK_SECRET=
