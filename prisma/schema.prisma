// Multi-Tenant Vault — PostgreSQL + Prisma
// Tenant isolation strategy: shared schema, every row scoped by tenantId.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// DEV 1 — Platform & Tenancy
// ─────────────────────────────────────────────
model Tenant {
  id        String       @id @default(uuid())
  name      String
  slug      String       @unique
  domain    String?      @unique
  status    TenantStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  users           User[]
  subscription    Subscription?
  business        Business?
  products        Product[]
  inventory       Inventory[]
  catalogs        Catalog[]
  documents       Document[]
  customers       Customer[]
  conversations   Conversation[]
  orders          Order[]
  quotes          Quote[]
  whatsappAccount WhatsappAccount?
  payments        Payment[]
  onboardingOverrides OnboardingOverride[]
  onboardingProgress  OnboardingProgress?
  paymentConfig       PaymentConfig?

  @@map("tenants")
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
}

model User {
  id           String   @id @default(uuid())
  tenantId     String?
  email        String
  passwordHash String
  name         String?
  roleId       String?
  isSuperAdmin Boolean  @default(false)
  isBanned     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant              Tenant?              @relation(fields: [tenantId], references: [id])
  role                Role?                @relation(fields: [roleId], references: [id])
  passwordResetTokens PasswordResetToken[]
  otpTokens           OtpToken[]
  refreshTokens       RefreshToken[]

  @@unique([tenantId, email])
  @@map("users")
}

model Role {
  id          String  @id @default(uuid())
  tenantId    String? // null = platform-level role
  name        String
  permissions Json    @default("[]")
  users       User[]

  @@unique([tenantId, name])
  @@map("roles")
}

model BillingPlan {
  id           String   @id @default(uuid())
  name         String   @unique // e.g. "monthly", "yearly"
  label        String // e.g. "Monthly Plan", "Yearly Plan"
  priceMinor   Int // price in kobo (NGN minor units)
  currency     String   @default("NGN")
  intervalDays Int // 30 for monthly, 365 for yearly
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  subscriptions Subscription[]

  @@map("billing_plans")
}

model Subscription {
  id            String             @id @default(uuid())
  tenantId      String             @unique
  planId        String?
  status        SubscriptionStatus @default(TRIAL)
  trialStartsAt DateTime           @default(now())
  trialEndsAt   DateTime
  renewsAt      DateTime?
  monnifyRef    String?
  meta          Json               @default("{}")
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  tenant Tenant       @relation(fields: [tenantId], references: [id])
  plan   BillingPlan? @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  CANCELLED
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id]) // 👈 only this line

  @@map("password_reset_tokens")
}

model OtpToken {
  id        String   @id @default(uuid())
  userId    String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("otp_tokens")
}

model RefreshToken {
  id         String   @id @default(uuid())
  userId     String
  jti        String   @unique
  lastUsedAt DateTime @default(now())
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────
// DEV 2 — Business, Products, Catalog, Website
// ─────────────────────────────────────────────
model Business {
  id              String           @id @default(uuid())
  tenantId        String           @unique
  displayName     String
  category        String?
  categoryOther   String?
  tagline         String?
  description     String?
  email           String?
  phone           String?          // ← new (Step 1)
  location        String?          // ← new (Step 1)
  whatsappNumber  String?
  logoUrl         String?
  logoStorageKey  String?
  settings        Json             @default("{}")

  // Compliance (Step 2)
  cacNumber       String?          // ← new
  tin             String?          // ← new

  // Operations (Step 3)
  activeClients   Int?             // ← new
  staffCount      Int?             // ← new
  monthlyRevenue  Int?             // ← new (stored in kobo/minor units)
  deliveryStructure String?        // ← new

  // Presence & hours (Step 4)
  instagram       String?          // ← new
  twitter         String?          // ← new
  facebook        String?          // ← new
  tiktok          String?          // ← new
  availableDays   String[]         // ← new (Postgres array)
  openingTime     String?          // ← new (e.g. "08:00")
  closingTime     String?          // ← new (e.g. "18:00")

  website         WebsitePage[]
  websiteSettings WebsiteSettings?
  tenant          Tenant @relation(fields: [tenantId], references: [id])

  @@map("businesses")
}

model WebsiteSettings {
  id         String   @id @default(uuid())
  businessId String   @unique
  theme      Json     @default("{}")
  navigation Json     @default("[]")
  seo        Json     @default("{}")
  social     Json     @default("{}")
  published  Boolean  @default(false)
  updatedAt  DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id])

  @@map("website_settings")
}

model Product {
  id              String   @id @default(uuid())
  tenantId        String
  name            String
  slug            String?
  sku             String?
  barcode         String?
  hsCode          String?
  category        String?
  brand           String?
  description     String?
  review          String?
  imageUrl        String?
  imageStorageKey String?
  galleryImages   Json     @default("[]")
  priceMinor      Int      @default(0)
  costPrice       Int?
  compareAtPrice  Int?
  currency        String   @default("NGN")
  attributes      Json     @default("{}")
  specifications  Json     @default("[]")
  features        Json     @default("[]")
  faqs            Json     @default("[]")
  seoMetadata     Json     @default("{}")
  tags            String[]
  collections     String[]
  stock           Int      @default(0)
  unit            String   @default("piece")
  minimumOrderQuantity Int  @default(1)
  isActive        Boolean  @default(true)
  isFeatured      Boolean  @default(false)
  sortOrder       Int      @default(0)
  relatedProductIds  String[]
  upsellProductIds   String[]
  crossSellProductIds String[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  tenant    Tenant          @relation(fields: [tenantId], references: [id])
  inventory Inventory?
  variants  ProductVariant[]

  @@index([tenantId])
  @@index([category])
  @@index([isFeatured])
  @@index([isActive])
  @@map("products")
}

model ProductVariant {
  id              String   @id @default(uuid())
  productId       String
  name            String
  sku             String?
  priceMinor      Int?
  stock           Int      @default(0)
  attributes      Json     @default("{}")
  imageUrl        String?
  imageStorageKey String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_variants")
}

model Inventory {
  id        String   @id @default(uuid())
  tenantId  String
  productId String   @unique
  quantity  Int      @default(0)
  reserved  Int      @default(0)
  lowStock  Int?
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("inventory")
}

model Catalog {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  data      Json     @default("{}")
  version   Int      @default(1)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("catalogs")
}

model WebsitePage {
  id         String  @id @default(uuid())
  businessId String
  slug       String
  title      String
  content    Json    @default("{}")
  published  Boolean @default(false)

  business Business @relation(fields: [businessId], references: [id])

  @@unique([businessId, slug])
  @@map("website_pages")
}

// ─────────────────────────────────────────────
// DEV 3 — Knowledge / RAG
// ─────────────────────────────────────────────
model Document {
  id        String   @id @default(uuid())
  tenantId  String
  filename  String
  mimeType  String
  size      Int?
  status    String   @default("pending")
  createdAt DateTime @default(now())

  tenant Tenant          @relation(fields: [tenantId], references: [id])
  chunks DocumentChunk[]

  @@index([tenantId])
  @@map("documents")
}

model DocumentChunk {
  id         String  @id @default(uuid())
  documentId String
  tenantId   String
  content    String
  vectorId   String? // id in Qdrant
  position   Int

  document Document @relation(fields: [documentId], references: [id])

  @@index([tenantId])
  @@map("document_chunks")
}

// ─────────────────────────────────────────────
// DEV 4 — Conversation, Orders, Quotes, WhatsApp
// ─────────────────────────────────────────────
model WhatsappAccount {
  id            String  @id @default(uuid())
  tenantId      String  @unique
  wabaId        String?
  phoneNumberId String?
  accessToken   String?
  verified      Boolean @default(false)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("whatsapp_accounts")
}

model Customer {
  id        String   @id @default(uuid())
  tenantId  String
  phone     String
  name      String?
  meta      Json     @default("{}")
  createdAt DateTime @default(now())

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  conversations Conversation[]

  @@unique([tenantId, phone])
  @@map("customers")
}

model Conversation {
  id         String   @id @default(uuid())
  tenantId   String
  customerId String
  channel    String   @default("whatsapp")
  status     String   @default("open")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  customer Customer  @relation(fields: [customerId], references: [id])
  messages Message[]

  @@index([tenantId])
  @@map("conversations")
}

model Message {
  id             String   @id @default(uuid())
  externalId     String?  @unique
  conversationId String
  role           String // customer|ai|staff
  content        String
  meta           Json     @default("{}")
  createdAt      DateTime @default(now())

  conversation   Conversation    @relation(fields: [conversationId], references: [id])
  mediaAssets    MediaAsset[]
  outboxMessages OutboxMessage[]

  @@index([conversationId])
  @@map("messages")
}

model MediaAsset {
  id              String   @id @default(uuid())
  tenantId        String
  messageId       String?
  provider        String // e.g. whatsapp
  providerMediaId String?
  mimeType        String?
  size            Int?
  storageKey      String
  url             String?
  meta            Json     @default("{}")
  createdAt       DateTime @default(now())

  message Message? @relation(fields: [messageId], references: [id])

  @@index([tenantId])
  @@map("media_assets")
}

model OutboxMessage {
  id               String    @id @default(uuid())
  tenantId         String
  channel          String    @default("whatsapp")
  to               String
  payload          Json
  messageId        String?
  attempts         Int       @default(0)
  status           String    @default("pending")
  lastError        String?
  scheduledAt      DateTime?
  sentAt           DateTime?
  providerResponse Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  message Message? @relation(fields: [messageId], references: [id])

  @@index([tenantId])
  @@index([messageId])
  @@map("outbox_messages")
}

model Order {
  id           String   @id @default(uuid())
  tenantId     String
  customerId   String?
  status       String   @default("pending")
  totalMinor   Int      @default(0)
  currency     String   @default("NGN")
  items        Json     @default("[]")
  measurements Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  payments Payment[]

  @@index([tenantId])
  @@map("orders")
}

model Quote {
  id          String   @id @default(uuid())
  tenantId    String
  customerId  String?
  status      String   @default("draft")
  amountMinor Int      @default(0)
  currency    String   @default("NGN")
  details     Json     @default("{}")
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("quotes")
}

model Payment {
  id                String   @id @default(uuid())
  tenantId          String
  orderId           String?
  reference         String   @unique
  provider          String   @default("monnify")
  providerReference String?  @unique
  amountMinor       Int      @default(0)
  currency          String   @default("NGN")
  status            String   @default("pending")
  meta              Json     @default("{}")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  order  Order? @relation(fields: [orderId], references: [id])

  @@index([tenantId])
  @@index([orderId])
  @@map("payments")
}

model PaymentConfig {
  id        String   @id @default(uuid())
  tenantId  String   @unique
  data      Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("payment_configs")
}

model OnboardingOverride {
  id          String   @id @default(uuid())
  tenantId    String
  step        String   // 'business' | 'whatsapp' | 'subscription'
  completedBy String   // userId of the admin who applied the override
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, step])
  @@index([tenantId])
  @@map("onboarding_overrides")
}

model OnboardingProgress {
  id           String    @id @default(uuid())
  tenantId     String    @unique
  currentStep  String    @default("business")
  startedAt    DateTime  @default(now())
  lastActiveAt DateTime  @updatedAt
  completedAt  DateTime?

  tenant   Tenant               @relation(fields: [tenantId], references: [id])
  stepData OnboardingStepData[]

  @@map("onboarding_progress")
}

model OnboardingStepData {
  id          String    @id @default(uuid())
  tenantId    String
  step        String    // 'business' | 'whatsapp' | 'subscription'
  data        Json
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  progress OnboardingProgress @relation(fields: [tenantId], references: [tenantId])

  @@unique([tenantId, step])
  @@index([tenantId])
  @@map("onboarding_step_data")
}